<Window x:Class="WpfApp1.CloseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        WindowStyle="None"
        Title="Main"
        Height="150"
        Width="400" 
        FontFamily="Cascadia Code" 
        Foreground="White" 
        Background="#1D2425" 
        FontSize="16"
        AllowsTransparency="True">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="0.15*"/>
            <RowDefinition Height="0.3*"/>
            <RowDefinition Height="0.3*"/>
            <RowDefinition Height="0.4*"/>
        </Grid.RowDefinitions>
        <Grid x:Name="header" Grid.ColumnSpan="4" Background="#434B4B" MouseDown="header_MouseDown">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="231*"/>
                <ColumnDefinition Width="169*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Выход" FontSize="11" VerticalAlignment="Center" Padding="10,0,0,0" />
            <Button x:Name="Close" Width="20" HorizontalAlignment="Right" BorderThickness="0"
                Background="#434B4B" FontFamily="Cascadia Code"
                Foreground="White" FontSize="10" Content="X" Grid.Column="1" Height="15" VerticalAlignment="Center" Click="Close_Click" />
        </Grid>
        <TextBlock Grid.Row="1" Grid.ColumnSpan="3" VerticalAlignment="Bottom" HorizontalAlignment="Center" FontSize="24" Text="Вы точно хотите выйти ">
        </TextBlock>
        <TextBlock Grid.Row="2" Grid.ColumnSpan="3" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="24" Text="из программы?">
        </TextBlock>

        <Button x:Name="cancelButton" Grid.Row="3" Grid.Column="0" Margin="15" FontFamily="Cascadia Code" 
Foreground="White" Background="#4b4b4b" Content="Назад" Click="cancelButton_Click"></Button>
        <Button x:Name="exitButton" Grid.Row="3" Grid.Column="1" Margin="15" FontFamily="Cascadia Code" 
Foreground="White" Background="#4b4b4b" Content="Выход" Click="exitButton_Click"></Button>
        <Button x:Name="hideButton" Grid.Row="3" Grid.Column="2" Margin="15" FontFamily="Cascadia Code" 
Foreground="White" Background="DarkOrange" Content="Свернуть" Click="hideButton_Click"></Button>
    </Grid>
</Window>
