<Window x:Class="WpfApp1.SelectWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        Title="SelectWindow"        
        WindowStyle="None"
        Height="150"
        Width="400" 
        FontFamily="Cascadia Code" 
        Foreground="White" 
        Background="#1D2425" 
        FontSize="16"
        AllowsTransparency="True">
    <Grid>
        <!--Макет-->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.5*"/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition Width="0.5*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="0.2*"/>
            <RowDefinition Height="0.4*"/>
            <RowDefinition Height="0.5*"/>
            <RowDefinition Height="0.7*"/>
            <RowDefinition Height="0.2*"/>
        </Grid.RowDefinitions>
        <!--Шапка-->
        <Grid x:Name="header" Grid.ColumnSpan="4" Background="#434B4B" MouseDown="header_MouseDown"  >
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="231*"/>
                <ColumnDefinition Width="169*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="BackupGuard(1.0.0-alpha)" FontSize="11" VerticalAlignment="Center" Padding="10,0,0,0" />
            <Button x:Name="Close" Width="20" HorizontalAlignment="Right" BorderThickness="0"
                Background="#434B4B" FontFamily="Cascadia Code"
                Foreground="White" FontSize="10" Content="X" Grid.Column="1" Height="15" VerticalAlignment="Center" Click="Close_Click" />
        </Grid>
        <ComboBox x:Name="select_comboBox" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Margin="5" >
            <ComboBoxItem Content="Выберите файл..." IsSelected="True"/>
            <ComboBoxItem Content="Локальная папка"/>
            <ComboBoxItem Content="Microsoft SQL Server"/>
        </ComboBox>
        <Button x:Name="closeButton" Grid.Row="3" Grid.Column="1" Margin="15" FontFamily="Cascadia Code" 
Foreground="White" Background="#4b4b4b" Content="Назад" Click="closeButton_Click" ></Button>
        <Button x:Name="selectButton" Grid.Row="3" Grid.Column="2" Margin="15" FontFamily="Cascadia Code" 
Foreground="White" Background="DarkOrange" Content="Продолжить" Click="selectButton_Click" ></Button>
    </Grid>
</Window>
