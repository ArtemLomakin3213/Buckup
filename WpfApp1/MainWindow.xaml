<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        WindowStyle="None"
        Title="Main"
        Height="500"
        Width="400" 
        FontFamily="Cascadia Code" 
        Foreground="White" 
        Background="#1D2425" 
        FontSize="16"
        AllowsTransparency="True" Loaded="Window_Loaded">
    <Grid>
        <!--Разметка формы-->
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="0.05*"/>
            <RowDefinition Height="0.15*"/>
            <RowDefinition Height="0.1*"/>
            <RowDefinition/>

            <RowDefinition Height="0.015*"/>
        </Grid.RowDefinitions>
        <!--Шапка программы-->
        <Grid x:Name="header" Grid.ColumnSpan="4" Background="#434B4B" MouseDown="header_MouseDown">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="231*"/>
                <ColumnDefinition Width="169*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="BackupGuard(1.0.0-alpha) " FontSize="11" VerticalAlignment="Center" Padding="10,0,0,0" Grid.ColumnSpan="2"/>
            <Button x:Name="Close" Width="20" Margin="147,2,0,0" HorizontalAlignment="Left" BorderThickness="0"
                Background="#434B4B" FontFamily="Cascadia Code"
                Foreground="White" FontSize="10" Content="X" Grid.Column="1" Height="15" VerticalAlignment="Top" Click="Close_Click"/>
            <Button x:Name="Hide" Width="20" Height="15" Margin="22,0" HorizontalAlignment="Right" BorderThickness="0"
                Background="#434B4B" FontFamily="Cascadia Code"
                Foreground="White" FontSize="10" Content="-" Grid.Column="1" Click="Hide_Click"/>
        </Grid>
                <!--Название программы-->
        <Grid Grid.Row="1" Grid.ColumnSpan="4" Background="#2F3738" Margin="5,0">
            <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="24px" FontWeight="Bold" Text="BackupGuard" />
        </Grid>

        <Button x:Name="download" Background="#434B4B" Foreground="White" Width="25" Height="25"  Grid.Column="3" Grid.Row="1" 
                HorizontalAlignment="Center" VerticalAlignment="Center" Content="⟳" FontSize="20" Padding="0,0,0,0" Click="download_Click">
            
        </Button>
        <!--Меню-->
        <Grid Grid.Row="2" Grid.ColumnSpan="4" >
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Button BorderThickness="0" Grid.Column="0" Margin="5,5,0,0"
                Background="#2F3738" FontFamily="Cascadia Code"
                Foreground="White" FontSize="16" Content="Главное меню"/>
            <Button BorderThickness="0" Grid.Column="1" Margin="0,5,5,0"
                Background="#1D2425" FontFamily="Cascadia Code" 
                Foreground="White" FontSize="16" Content="Настройки"/>
        </Grid>
        <Grid Grid.Row="3"  Grid.ColumnSpan="4" Margin="5,0" Background="#2F3738">
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition Height="0.1*"/>
                <RowDefinition Height="0.1*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition></ColumnDefinition>
                <ColumnDefinition></ColumnDefinition>
                <ColumnDefinition Width="0.8*"></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <ListBox x:Name="list_listbox" Grid.ColumnSpan="3" Background="#2F3738"  
                 Foreground="White" 
                 BorderThickness="0"
                 ItemsSource="{Binding AllItem}"
                 DisplayMemberPath="Name"
                 SelectedValuePath="Id">
            </ListBox>


            <Button x:Name="add_button" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Margin="3" FontFamily="Cascadia Code"
Foreground="White" FontSize="16" Background="DarkOrange" Content="Добавить новый файл" Click="Add_Click"></Button>
            <Button x:Name="backup_button" Grid.Row="2" Grid.Column="2" Margin="3" FontFamily="Cascadia Code"
Foreground="White" FontSize="16" Background="#434B4B" Content="Копирование" Click="backup_button_Click"></Button>
            <Button x:Name="delete_button" Grid.Row="2" Grid.Column="1" Margin="3" FontFamily="Cascadia Code"
Foreground="White" FontSize="16" Background="#434B4B" Content="Удалить" Height="25" VerticalAlignment="Top" Click="delete_button_Click"></Button>
            <Button x:Name="update_button" Grid.Row="2" Grid.Column="0" Margin="3" FontFamily="Cascadia Code"
Foreground="White" FontSize="16" Background="#434B4B" Content="Изменить" Click="update_button_Click"></Button>
        </Grid>
    </Grid>
</Window>
